{
    "_comment": "Example configuration for cadastre area search with type-ahead combo box using search.wsgi",
    "_note": "The WSGI script returns both 'ko_id' (code value for filtering) and 'displaytext' (formatted display text)",
    "search": [
        {
            "title": "Parcele",
            "useWmsRequest": true,
            "queryLayer": "parcele_layer",
            "formItems": [
                {
                    "xtype": "combo",
                    "fieldLabel": "Katastrska občina",
                    "name": "ko_id",
                    "displayField": "displaytext",
                    "valueField": "ko_id",
                    "typeAhead": true,
                    "mode": "remote",
                    "triggerAction": "all",
                    "minChars": 2,
                    "queryDelay": 100,
                    "allowBlank": false,
                    "blankText": "Vnesi številko ali ime k.o.",
                    "filterOp": "=",
                    "store": {
                        "xtype": "jsonstore",
                        "url": "wsgi/search.wsgi",
                        "baseParams": {
                            "searchtables": "search_ko",
                            "srs": "3794",
                            "limit": "20"
                        },
                        "root": "results",
                        "fields": [
                            {"name": "ko_id", "type": "string"},
                            {"name": "displaytext", "type": "string"},
                            {"name": "searchtable", "type": "string"},
                            {"name": "bbox", "type": "auto"},
                            {"name": "showlayer", "type": "string"},
                            {"name": "selectable", "type": "string"},
                            {"name": "geometry", "type": "auto"}
                        ]
                    },
                    "tpl": "<tpl for=\".\"><div class=\"x-combo-list-item\">{displaytext}</div></tpl>",
                    "itemSelector": "div.x-combo-list-item",
                    "listWidth": 300
                },
                {
                    "xtype": "textfield",
                    "name": "st_parcele",
                    "fieldLabel": "Številka parcele",
                    "filterOp": "=",
                    "allowBlank": true,
                    "blankText": "Vnesi številko parcele"
                }
            ],
            "gridColumns": [
                {
                    "header": "Katastrska občina",
                    "dataIndex": "displaytext",
                    "menuDisabled": "true"
                },
                {
                    "header": "Št. parcele",
                    "dataIndex": "st_parcele",
                    "menuDisabled": "true"
                }
            ],
            "selectionLayer": "parcele_layer",
            "selectionZoom": 0,
            "doZoomToExtent": true
        },
        {
            "title": "Stavbe",
            "useWmsRequest": true,
            "queryLayer": "stavbe_layer",
            "formItems": [
                {
                    "xtype": "combo",
                    "fieldLabel": "Katastrska občina",
                    "name": "ko_id",
                    "displayField": "displaytext",
                    "valueField": "ko_id",
                    "typeAhead": true,
                    "mode": "remote",
                    "triggerAction": "all",
                    "minChars": 2,
                    "queryDelay": 100,
                    "allowBlank": false,
                    "blankText": "Vnesi številko ali ime k.o.",
                    "filterOp": "=",
                    "store": {
                        "xtype": "jsonstore",
                        "url": "wsgi/search.wsgi",
                        "baseParams": {
                            "searchtables": "search_ko",
                            "srs": "3794",
                            "limit": "20"
                        },
                        "root": "results",
                        "fields": [
                            {"name": "ko_id", "type": "string"},
                            {"name": "displaytext", "type": "string"},
                            {"name": "searchtable", "type": "string"},
                            {"name": "bbox", "type": "auto"},
                            {"name": "showlayer", "type": "string"},
                            {"name": "selectable", "type": "string"},
                            {"name": "geometry", "type": "auto"}
                        ]
                    },
                    "tpl": "<tpl for=\".\"><div class=\"x-combo-list-item\">{displaytext}</div></tpl>",
                    "itemSelector": "div.x-combo-list-item",
                    "listWidth": 300
                },
                {
                    "xtype": "textfield",
                    "name": "st_parcele",
                    "fieldLabel": "Številka parcele",
                    "_note": "Change 'st_parcele' to appropriate field name for buildings (e.g., 'st_stavbe') based on your database schema",
                    "filterOp": "=",
                    "allowBlank": true,
                    "blankText": "Vnesi številko parcele"
                }
            ],
            "gridColumns": [
                {
                    "header": "Katastrska občina",
                    "dataIndex": "displaytext",
                    "menuDisabled": "true"
                },
                {
                    "header": "Št. parcele",
                    "dataIndex": "st_parcele",
                    "_note": "Change to appropriate field name for buildings based on your database schema",
                    "menuDisabled": "true"
                }
            ],
            "selectionLayer": "stavbe_layer",
            "selectionZoom": 0,
            "doZoomToExtent": true
        }
    ]
}
